# Server
PORT=5000
NODE_ENV=development

# Database (Postgres) - replace with your own (Neon / Supabase / Railway / local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/rentnest?schema=public"

# JWT
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Admin seed credentials (used by prisma/seed.ts)
ADMIN_EMAIL=admin@rentnest.com
ADMIN_PASSWORD=admin123

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
CLIENT_SUCCESS_URL=http://localhost:5000/api/payments/success
CLIENT_CANCEL_URL=http://localhost:5000/api/payments/cancel
